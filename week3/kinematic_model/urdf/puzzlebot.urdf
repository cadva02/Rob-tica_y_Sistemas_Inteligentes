<?xml version="1.0"?>
<robot name="kinematic_model">

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.06" rpy="1.5708 0 3.1416"/>
      <geometry>
        <mesh filename="package://kinematic_model/meshes/MCR2_puzzlebot_jetson_lidar_base.stl"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <link name="chassis"/>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="package://kinematic_model/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
      <geometry>
        <mesh filename="package://kinematic_model/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="caster_ball">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://kinematic_model/meshes/Puzzlebot_Caster_Wheel.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="base_laser">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

  <joint name="wheel_left_joint" type="fixed">
    <parent link="chassis"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.08 -0.08" rpy="0 0 0"/>
  </joint>

  <joint name="wheel_right_joint" type="fixed">
    <parent link="chassis"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.08 -0.08" rpy="0 0 0"/>
  </joint>

  <joint name="caster_ball_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_ball"/>
    <origin xyz="-0.11 0 -0.08" rpy="0 0 0"/>
  </joint>

  <joint name="base_laser_joint" type="fixed">
    <parent link="chassis"/>
    <child link="base_laser"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

</robot>
